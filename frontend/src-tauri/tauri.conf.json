{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veyra",
  "version": "0.3.0",
  "identifier": "com.thequaniac.veyra",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5188",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Veyra",
        "width": 1320,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/android/mipmap-mdpi/ic_launcher.png",
      "icons/android/mipmap-hdpi/ic_launcher.png",
      "icons/android/mipmap-xhdpi/ic_launcher.png",
      "icons/android/mipmap-xxhdpi/ic_launcher.png",
      "icons/android/mipmap-xxxhdpi/ic_launcher.png"
    ],
    "android": {
      "minSdkVersion": 24
    }
  }
}
